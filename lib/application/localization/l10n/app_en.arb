{
  "appTitle": "Pet Crypto",
  "@appTitle": {
    "description": "App Title"
  },
  "dashboardTitle": "Dashboard",
  "@dashboardTitle": {
    "description": "Dashboard Title"
  },
  "profileTitle": "Profile",
  "@profileTitle": {
    "description": "Profile Title"
  },
  "dashboardCryptoTitle": "{name} ({symbol})",
  "@dashboardCryptoTitle": {
    "description": "Title of crypto",
    "placeholders": {
      "name": {
        "type": "String",
        "example": "Bitcoin"
      },
      "symbol": {
        "type": "String",
        "example": "BTC"
      }
    }
  },
  "dashboardPriceCrypto": "{currencyCode}: {value}",
  "@dashboardPriceCrypto": {
    "description": "Price of crypto",
    "placeholders": {
      "currencyCode": {
        "type": "String",
        "example": "USD"
      },
      "value": {
        "type": "double",
        "example": "1.1"
      }
    }
  },
  "profileTheme": "Theme",
  "@profileTheme": {
    "description": "Title of theme mode block"
  },
  "profileLocalization": "Localization",
  "@profileLocalization": {
    "description": "Title of localization block"
  },
  "profileLogout": "Logout",
  "@profileLogout": {
    "description": "Logout button text"
  },
  "authorizationLogin": "Login",
  "@authorizationLogin": {
    "description": "Login button text"
  }
}