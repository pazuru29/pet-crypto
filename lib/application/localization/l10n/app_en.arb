{
  "appTitle": "Pet Crypto",
  "@appTitle": {
    "description": "App Title"
  },
  "dashboardTitle": "Dashboard",
  "@dashboardTitle": {
    "description": "Dashboard Title"
  },
  "profileTitle": "Profile",
  "@profileTitle": {
    "description": "Profile Title"
  },
  "dashboardCryptoTitle": "{name} ({symbol})",
  "@dashboardCryptoTitle": {
    "description": "Title of crypto",
    "placeholders": {
      "name": {
        "type": "String",
        "example": "Bitcoin"
      },
      "symbol": {
        "type": "String",
        "example": "BTC"
      }
    }
  },
  "dashboardPriceCrypto": "{currencyCode}: {value}",
  "@dashboardPriceCrypto": {
    "description": "Price of crypto",
    "placeholders": {
      "currencyCode": {
        "type": "String",
        "example": "USD"
      },
      "value": {
        "type": "double",
        "example": "1.1"
      }
    }
  },
  "profileTheme": "Theme",
  "@profileTheme": {
    "description": "Title of theme mode block"
  },
  "profileLocalization": "Localization",
  "@profileLocalization": {
    "description": "Title of localization block"
  },
  "profileLogout": "Logout",
  "@profileLogout": {
    "description": "Logout button text"
  },
  "loginButton": "Login",
  "@loginButton": {
    "description": "Login button text"
  },
  "loginTitle": "LogIn",
  "@loginTitle": {
    "description": "Title of login screen"
  },
  "loginUsername": "Username",
  "@loginUsername": {
    "description": "Hint of username text filed"
  },
  "loginPassword": "Password",
  "@loginPassword": {
    "description": "Hint of password text filed"
  },
  "loginCorrectUsername": "Please enter the correct username",
  "@loginCorrectUsername": {
    "description": "Text displayed after a failed username validation"
  },
  "loginCorrectPassword": "Please enter the correct password",
  "@loginCorrectPassword": {
    "description": "Text displayed after a failed password validation"
  },
  "loginLengthPassword": "The password must be {count} characters or more",
  "@loginLengthPassword": {
    "description": "Text displayed after a failed password length check",
    "placeholders": {
      "count": {
        "type": "int",
        "example": "8"
      }
    }
  }
}